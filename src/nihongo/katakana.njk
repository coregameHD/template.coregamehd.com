<!-- Tabler Core JS -->
<script src="https://unpkg.com/@tabler/core@latest/dist/js/tabler.min.js"></script>
<!-- Tom Select JS -->
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>

<script>
    // Initialize Tom Select
    const wordTypesSelect = new TomSelect('#word-types', {
        plugins: ['remove_button','clear_button'],
        maxItems: null,
        persist: false,
        create: false,
        onChange: function() {
            updatePreview();
        }
    });

    const japaneseTextInput = document.getElementById('japanese-text');
    const originalLanguageTextInput = document.getElementById('original-language-text');
    const thaiTextInput = document.getElementById('thai-text');
    const descriptionInput = document.getElementById('description');
    const gameTitleInput = document.getElementById('game-title');
    const previewOutput = document.getElementById('preview');
    const copyButton = document.getElementById('copyButton');
    const nLevelSelect = document.getElementById('n-level');
    const jlptLevelSelect = document.getElementById('jlpt-level');
    const yearInput = document.getElementById('year');
    const monthInput = document.getElementById('month');
    const jlptExamCheckbox = document.getElementById('jlpt-exam');
    const jtestExamCheckbox = document.getElementById('jtest-exam');
    const jtestNoInput = document.getElementById('jtest-no');

    // Initialize jtest-no input as disabled
    jtestNoInput.disabled = true;

    // Add N-level dependency logic
    if (nLevelSelect) {
        nLevelSelect.addEventListener('change', function() {
            const selectedValue = this.value;
            if (selectedValue !== 'None' && jlptExamCheckbox && jlptExamCheckbox.checked) {
                if (jlptLevelSelect) jlptLevelSelect.value = selectedValue;
                if (yearInput) yearInput.value = new Date().getFullYear();
                if (monthInput) monthInput.value = new Date().getMonth() + 1;
            }
            updatePreview();
        });
    }

    // Add JLPT exam checkbox dependency logic
    if (jlptExamCheckbox) {
        jlptExamCheckbox.addEventListener('change', function() {
            if (jlptLevelSelect) jlptLevelSelect.disabled = !this.checked;
            if (yearInput) yearInput.disabled = !this.checked;
            if (monthInput) monthInput.disabled = !this.checked;
            if (this.checked) {
                const nLevelValue = nLevelSelect ? nLevelSelect.value : 'None';
                if (nLevelValue !== 'None') {
                    if (jlptLevelSelect) jlptLevelSelect.value = nLevelValue;
                    if (yearInput) yearInput.value = new Date().getFullYear();
                    if (monthInput) monthInput.value = new Date().getMonth() + 1;
                }
            }
            updatePreview();
        });
    }

    // Add JTest exam checkbox dependency logic
    if (jtestExamCheckbox && jtestNoInput) {
        jtestExamCheckbox.addEventListener('change', function() {
            jtestNoInput.disabled = !this.checked;
            updatePreview();
        });
    }

    function updatePreview() {
        if (!previewOutput) return;
        
        // Safely get values with null checks
        let japaneseText = japaneseTextInput ? japaneseTextInput.value : '';
        let originalLanguageText = originalLanguageTextInput ? originalLanguageTextInput.value : '';
        let thaiText = thaiTextInput ? thaiTextInput.value : '';
        let description = descriptionInput ? descriptionInput.value : '';
        let gameTitle = gameTitleInput ? gameTitleInput.value : '';
        let nLevel = nLevelSelect ? nLevelSelect.value : 'None';
        
        // Safely get selected word types
        let selectedWordTypes = '';
        if (wordTypesSelect && wordTypesSelect.items) {
            selectedWordTypes = wordTypesSelect.items
                .map(value => wordTypesSelect.options[value] ? wordTypesSelect.options[value].text : '')
                .filter(Boolean)
                .join(' / ');
        }
        
        let year = yearInput ? yearInput.value : '';
        let month = monthInput ? monthInput.value : '';
        let jlptText = "";
        let jtestText = "";

        let output = `【คำศัพท์】\n\n${japaneseText}\n${originalLanguageText}\n${thaiText}\n\n※ ${selectedWordTypes}`;

        if (nLevel !== "None") {
            output += `\n※ คำศัพท์ระดับ ${nLevel}`;
        }

        if (jlptExamCheckbox && jlptExamCheckbox.checked && jlptLevelSelect) {
            let jlptLevel = jlptLevelSelect.value || '';
            if (jlptLevel && year && month) {
                jlptText = `\n⭐️ ออกสอบ JLPT ${jlptLevel} (รอบ ${year}年${month}月)`;
                output += jlptText;
            }
        }

        if (jtestExamCheckbox && jtestExamCheckbox.checked && jtestNoInput && jtestNoInput.value) {
            jtestText = `\n⭐️ ออกสอบ J.TEST ระดับ A-C (第${jtestNoInput.value}回)`;
            output += jtestText;
        }

        // Build the meaning section
        output += '\n\n————————————\n';
        if (japaneseText) output += japaneseText + '\n';
        if (description) output += description;
        
        // Add game title if available
        if (gameTitle) {
            output += '\n\n————————————\n▍ภาพจากเกม ' + gameTitle;
        }

        previewOutput.textContent = output;
    }

    // Add event listeners for all inputs
    const textInputs = [
        japaneseTextInput, originalLanguageTextInput, thaiTextInput, 
        descriptionInput, gameTitleInput, jtestNoInput, 
        yearInput, monthInput
    ].filter(Boolean); // Remove any null/undefined values
    
    const selectInputs = [nLevelSelect, jlptLevelSelect].filter(Boolean);
    const checkboxInputs = [jlptExamCheckbox, jtestExamCheckbox].filter(Boolean);

    // Add input event listeners to text inputs
    textInputs.forEach(input => {
        input.addEventListener('input', updatePreview);
    });

    // Add change event listeners to select inputs
    selectInputs.forEach(select => {
        select.addEventListener('change', updatePreview);
    });

    // Add change event to Tom Select
    if (wordTypesSelect) {
        wordTypesSelect.on('change', updatePreview);
    }

    // Add change event listeners to checkboxes
    checkboxInputs.forEach(checkbox => {
        checkbox.addEventListener('change', updatePreview);
    });

    // Initial preview update
    updatePreview();

    // Add click event to copy button
    if (copyButton) {
        copyButton.addEventListener('click', async function() {
            const textToCopy = previewOutput ? previewOutput.textContent.trim() : '';
            
            if (!textToCopy) {
                showToast('No content to copy!', 'error');
                return;
            }
            
            try {
                await navigator.clipboard.writeText(textToCopy);
                showToast('Copied to clipboard!', 'success');
            } catch (err) {
                console.error('Failed to copy text: ', err);
                showToast('Failed to copy. Please try again.', 'error');
            }
        });
    }

    // Add click event to clear all button
    if (clearAllBtn) {
        clearAllBtn.addEventListener('click', function() {
            // Clear all input fields
            const form = document.querySelector('form');
            if (form) form.reset();
            
            // Clear Tom Select
            if (wordTypesSelect) {
                wordTypesSelect.clear();
            }
            
            // Reset disabled states
            if (jtestNoInput) jtestNoInput.disabled = true;
            if (jlptLevelSelect) jlptLevelSelect.disabled = true;
            if (yearInput) yearInput.disabled = true;
            if (monthInput) monthInput.disabled = true;
            
            // Update preview
            updatePreview();
            
            // Show success message
            showToast('All fields have been cleared!', 'success');
        });
    }
    // Toast notification function
    function showToast(message, type = 'success') {
        // Create toast container if it doesn't exist
        let toastContainer = document.querySelector('.toast-container');
        if (!toastContainer) {
            toastContainer = document.createElement('div');
            toastContainer.className = 'toast-container position-fixed top-0 end-0 p-3';
            toastContainer.style.zIndex = '1090';
            document.body.appendChild(toastContainer);
        }
        
        const toastId = 'toast-' + Date.now();
        const toast = document.createElement('div');
        toast.id = toastId;
        
        // Use Tabler's alert classes
        const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
        const iconClass = type === 'success' ? 'ti-circle-check' : 'ti-alert-circle';
        
        toast.className = `alert ${alertClass} alert-dismissible fade show`;
        toast.role = 'alert';
        
        toast.innerHTML = `
            <div class="d-flex align-items-center">
                <i class="ti ${iconClass} me-2"></i>
                <div>${message}</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
        
        toastContainer.appendChild(toast);
        
        // Auto remove toast after delay
        setTimeout(() => {
            toast.classList.remove('show');
            toast.classList.add('fade');
            setTimeout(() => {
                toast.remove();
                if (toastContainer && toastContainer.children.length === 0) {
                    toastContainer.remove();
                }
            }, 150);
        }, 3000);
        
        // Add close button functionality
        const closeBtn = toast.querySelector('.btn-close');
        if (closeBtn) {
            closeBtn.addEventListener('click', () => {
                toast.classList.remove('show');
                toast.classList.add('fade');
                setTimeout(() => {
                    toast.remove();
                    if (toastContainer && toastContainer.children.length === 0) {
                        toastContainer.remove();
                    }
                }, 150);
            });
        }
    }

    // Initialize form state
    updatePreview();
</script>

</body>
</html>
