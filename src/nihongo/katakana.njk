    .card-header {
        background-color: #fff;
        border-bottom: 1px solid rgba(255, 64, 129, 0.1);
        font-weight: 600;
        color: var(--brand-dark);
    }
    .preview-output {
        min-height: 400px;
        background-color: #1a1a1a;
