---
layout: layouts/base.njk
title: Japanese Vocabulary
pageScript: /js/nihongo.js
---

<div class="container-xl py-4">
    <div class="row g-4">
        <!-- Column 1 -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Japanese Text</h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Japanese Text</label>
                        <input type="text" class="form-control" id="japanese-text" placeholder="Enter Japanese text">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reading (Optional)</label>
                        <input type="text" class="form-control" id="reading-text" placeholder="Enter reading (optional)">
                    </div>
                    <button id="add-word-btn" class="btn btn-primary w-100">Add to List</button>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h3 class="card-title">Word List</h3>
                </div>
                <div class="card-body">
                    <div id="word-list" class="list-group">
                        <!-- Word items will be added here -->
                    </div>
                    <div class="d-grid gap-2 mt-3">
                        <button id="clear-list-btn" class="btn btn-outline-danger">Clear List</button>
                        <button id="export-json-btn" class="btn btn-outline-secondary">Export as JSON</button>
                        <button id="import-json-btn" class="btn btn-outline-primary">Import JSON</button>
                        <input type="file" id="import-json-file" accept=".json" style="display: none;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Column 2 -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title">Dictionary Lookup</h3>
                    <div>
                        <button id="lookup-btn" class="btn btn-primary">Lookup</button>
                        <button id="clear-lookup-btn" class="btn btn-outline-secondary">Clear</button>
                    </div>
                </div>
                <div class="card-body">
                    <div id="dictionary-results">
                        <!-- Dictionary results will be displayed here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast container for notifications -->
<div id="toast-container" class="position-fixed bottom-0 end-0 p-3" style="z-index: 11"></div>
