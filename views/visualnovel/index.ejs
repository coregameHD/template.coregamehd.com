<%- include('../partials/head', { title: "Kagami Visual Novel Post Generator", cssFile: "visualnovel", faviconPath: "/img/favicon_kagamivisualnovel.png" }) %>
<body>
    <%- include('../partials/navbar_visualnovel') %>

    <div class="page-wrapper flex-grow-1" style="padding-top: 2rem;">
        <div class="container-xl">
            <div class="row g-4">
                <!-- Snippet Library Column -->
                <div class="col-lg-4 col-xl-3">
                    <div class="card h-100">
                        <div class="card-header">
                            <h3 class="card-title mb-1">Tools</h3>
                        </div>
                        <div class="card-body p-0">
                            <div class="p-3 border-bottom ">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                                    <h4 class="fw-semibold">Template (Media)</h4>
                                </div>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-outline-primary insert-snippet"
                                        data-snippet="【MEDIA】 ⇒ Illustration

Character ⋮
VN ⋮

� Source ⋮ ">
                                        รูปวาด (Illustration)
                                    </button>
                                    <button class="btn btn-outline-primary insert-snippet"
                                        data-snippet="【MEDIA】 ⇒ Merchandise

🔗 Website ⋮ ">
                                        สินค้า (Merchandise)
                                    </button>
                                    <button class="btn btn-outline-primary insert-snippet"
                                        data-snippet="【MEDIA】 ⇒ Music

เพลง OP จากเกม 

ชื่อเพลง
ร้องโดย

🔗 Youtube ⋮ ">
                                        เพลง (Music)
                                    </button>
                                    <button class="btn btn-outline-primary insert-snippet"
                                        data-snippet="【MEDIA】 ⇒ Screenshots

รวมภาพ Sample CG จากเกม

🔗 Website ⋮ ">
                                        ภาพประกอบ (Screenshots)
                                    </button>
                                </div>
                            </div>
                            <div class="p-3 border-bottom ">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                                    <h4 class="fw-semibold">Template (เกมฝั่งอังกฤษ)</h4>
                                </div>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-outline-success insert-snippet"
                                        data-snippet="【NEWS】 ⇒ Announcements

ผู้ดูแลด้านภาษาและจัดจำหน่าย {publisher}
ประกาศลิขสิทธิ์แปลเกมเวอร์ชั่นภาษาอังกฤษ

{description}

🔗 Steam ⋮ {link}
� Release Date ⋮ {date}">
                                        ประกาศลิขสิทธิ์
                                    </button>
                                    <button class="btn btn-outline-success insert-snippet"
                                        data-snippet="【NEWS】 ⇒ Updates

ผู้ดูแลด้านภาษาและจัดจำหน่าย {publisher} อัปเดตข้อมูลใหม่
เปิดหน้าร้านค้า Steam

{romaji}
{japanese}
(ชื่ออังกฤษ: {englishtitle})

{description}

🔗 Steam ⋮ {link}
📅 Release Date ⋮ {date}">
                                        ขึ้นรายละเอียดบนร้านค้า Steam
                                    </button>
                                    <button class="btn btn-outline-success insert-snippet"
                                        data-snippet="【NEWS】 ⇒ Updates

ผู้ดูแลด้านภาษาและจัดจำหน่าย {publisher} อัปเดตข้อมูลใหม่
กำหนดวันวางจำหน่ายเกมเวอร์ชั่นภาษาอังกฤษ

{romaji}
{japanese}
(ชื่ออังกฤษ: {englishtitle})

{description}

🔗 Steam ⋮ {link}
📅 Release Date ⋮ {date} (Confirmed)">
                                        กำหนดวันวางจำหน่าย
                                    </button>
                                    <button class="btn btn-outline-success insert-snippet"
                                        data-snippet="【NEWS】 ⇒ Updates

ผู้ดูแลด้านภาษาและจัดจำหน่าย {publisher}
วางจำหน่ายเกมเวอร์ชั่นภาษาอังกฤษ

{romaji}
{japanese}
(ชื่ออังกฤษ: {englishtitle})

{description}

💰 ราคา ⋮ {price} บาท (ลด {percent}% จนถึงวันที่ {discountdate})
🔗 Steam ⋮ {link}">
                                        วางจำหน่ายเกม
                                    </button>
                                </div>
                            </div>
                            <div class="list-group list-group-flush">
                                <div class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2">
                                    <div>
                                        <div class="fw-semibold">หัวข้อข่าว</div>
                                        <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                                            <select id="greetingSelect" class="form-select form-select-sm w-auto">
                                                <option value="【NEWS】 ⇒ Announcements">【NEWS】 ⇒ Announcements</option>
                                                <option value="【NEWS】 ⇒ Updates">【NEWS】 ⇒ Updates</option>
                                                <option disabled>──────────</option>
                                                <option value="【MEDIA】 ⇒ Illustration">【MEDIA】 ⇒ Illustration</option>
                                                <option value="【MEDIA】 ⇒ Merchandise">【MEDIA】 ⇒ Merchandise</option>
                                                <option value="【MEDIA】 ⇒ Music">【MEDIA】 ⇒ Music</option>
                                                <option value="【MEDIA】 ⇒ Screenshots">【MEDIA】 ⇒ Screenshots</option>
                                            </select>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-primary insert-snippet"
                                        data-snippet-select="greetingSelect"
                                        data-snippet="Hello World!\n\n">
                                        Insert
                                    </button>
                                </div>

                                <div class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2">
                                    <div>
                                        <div class="fw-semibold">Hyperlink</div>
                                        <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                                            <select id="storyHookSelect" class="form-select form-select-sm w-auto">
                                                <option value="🔗 Website ⋮ ">Website</option>
                                                <option value="🔗 X (Twitter) ⋮ ">X (Twitter)</option>
                                                <option value="🔗 Youtube ⋮ ">Youtube</option>
                                                <option value="🔗 Steam ⋮ ">Steam</option>
                                                <option disabled>──────────</option>
                                                <option value="🔗 Source ⋮ ">Source</option>
                                            </select>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-primary insert-snippet"
                                        data-snippet-select="storyHookSelect"
                                        data-snippet="Chapter Update:\n- Title: [Enter title]\n- Summary: [Add summary here]\n\n">
                                        Insert
                                    </button>
                                </div>

                                <div class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2">
                                    <div>
                                        <div class="fw-semibold">วันที่จัดจำหน่าย</div>
                                    </div>
                                    <button class="btn btn-sm btn-primary insert-snippet"
                                        data-snippet="📅 Release Date ⋮ {date}
">
                                        Insert
                                    </button>
                                </div>

                                <div class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2">
                                    <div>
                                        <div class="fw-semibold">หมายเหตุ</div>
                                    </div>
                                    <button class="btn btn-sm btn-primary insert-snippet"
                                        data-snippet="————————————
* หมายเหตุ ⋮ ">
                                        Insert
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Editor Column -->
                <div class="col-lg-8 col-xl-9">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <h3 class="card-title mb-1">Post Draft</h3>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-danger btn-sm" id="clearEditorBtn">
                                    <i class="fas fa-trash me-2"></i>Clear Editor
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" id="copyEditorBtn">
                                    <i class="fas fa-copy me-2"></i>Copy Draft
                                </button>
                            </div>
                        </div>
                        <!-- Arrow Process Diagram -->
                        <div class="px-4 py-3 border-bottom process-diagram">
                            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                <div class="dropdown">
                                    <button class="btn btn-outline-primary dropdown-toggle process-btn flex-shrink-0" type="button" data-bs-toggle="dropdown" data-action="announcements">
                                        <i class="fas fa-bullhorn me-1"></i>Announcements
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item announcement-option" href="#" data-option="new-game">เปิดตัวเกมใหม่</a></li>
                                        <li><a class="dropdown-item announcement-option" href="#" data-option="other">อื่นๆ</a></li>
                                    </ul>
                                </div>
                                <i class="fas fa-arrow-right text-muted flex-shrink-0"></i>
                                <div class="dropdown">
                                    <button class="btn btn-outline-primary dropdown-toggle process-btn flex-shrink-0" type="button" data-bs-toggle="dropdown" data-action="updates">
                                        <i class="fas fa-sync me-1"></i>Updates
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item update-option" href="#" data-option="website">เปิดตัวเว็บไซต์</a></li>
                                        <li><a class="dropdown-item update-option" href="#" data-option="cast">เปิดเผยรายชื่อนักพากย์</a></li>
                                        <li><a class="dropdown-item update-option" href="#" data-option="release-date">กำหนดวันวางจำหน่าย</a></li>
                                        <li><a class="dropdown-item update-option" href="#" data-option="delay">เลื่อนวันวางจำหน่าย</a></li>
                                        <li><a class="dropdown-item update-option" href="#" data-option="other">อื่นๆ</a></li>
                                    </ul>
                                </div>
                                <i class="fas fa-arrow-right text-muted flex-shrink-0"></i>
                                <button class="btn btn-outline-primary process-btn flex-shrink-0" data-action="trial">
                                    <i class="fas fa-flask me-1"></i>Trial Version
                                </button>
                                <i class="fas fa-arrow-right text-muted flex-shrink-0"></i>
                                <button class="btn btn-outline-primary process-btn flex-shrink-0" data-action="masterup">
                                    <i class="fas fa-star me-1"></i>Master up
                                </button>
                                <i class="fas fa-arrow-right text-muted flex-shrink-0"></i>
                                <button class="btn btn-outline-primary process-btn flex-shrink-0" data-action="newrelease">
                                    <i class="fas fa-rocket me-1"></i>New Release
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <textarea id="visualNovelEditor" class="form-control border-0 rounded-0" spellcheck="false"
                                style="min-height: 70vh; resize: vertical; font-size: 1.1rem;"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const editor = document.getElementById('visualNovelEditor');
            const snippetButtons = document.querySelectorAll('.insert-snippet');
            const clearBtn = document.getElementById('clearEditorBtn');
            const copyBtn = document.getElementById('copyEditorBtn');
            const processButtons = document.querySelectorAll('.process-btn');

            const insertAtCursor = (text) => {
                const start = editor.selectionStart ?? editor.value.length;
                const end = editor.selectionEnd ?? editor.value.length;
                const before = editor.value.substring(0, start);
                const after = editor.value.substring(end);
                editor.value = `${before}${text}${after}`;
                const cursorPosition = start + text.length;
                editor.selectionStart = cursorPosition;
                editor.selectionEnd = cursorPosition;
                editor.focus();
            };

            snippetButtons.forEach((btn) => {
                btn.addEventListener('click', () => {
                    const selectId = btn.dataset.snippetSelect;
                    let snippet = btn.dataset.snippet || '';

                    if (selectId) {
                        const selectEl = document.getElementById(selectId);
                        if (selectEl) {
                            snippet = selectEl.value || snippet;
                        }
                    }

                    insertAtCursor(snippet);
                });
            });

            // Process button event listeners
            processButtons.forEach((btn) => {
                btn.addEventListener('click', () => {
                    const action = btn.dataset.action;
                    
                    // Skip announcements and updates actions as they are handled by dropdowns
                    if (action === 'announcements' || action === 'updates') {
                        return;
                    }
                    
                    if (action === 'trial') {
                        const trialText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
เปิดให้ดาวน์โหลดไทเค็นบัง (เวอร์ชั่นทดลองเล่น)

{romaji}
{japanese}

🔗 Download (Trial Edition) ⋮ {link}
📅 Release Date ⋮ {date}`;
                        insertAtCursor(trialText);
                    } else if (action === 'masterup') {
                        const masterUpText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
ประกาศ Master up (เข้าสู่ขั้นตอนการผลิต)

{romaji}
{japanese}

ยืนยันวันวางจำหน่าย {date}

🔗 Website ⋮ {link}

————————————
Master up - แผ่นเกมต้นฉบับเข้าสู่กระบวนการผลิตเตรียมพร้อมสำหรับจัดจำหน่าย อนุมานได้ว่ามีโอกาส 99.95% ที่จะไม่เลื่อนวันวางขาย`;
                        insertAtCursor(masterUpText);
                    } else if (action === 'newrelease') {
                        const newReleaseText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
วางจำหน่ายเกมอย่างเป็นทางการ

{romaji}
{japanese}

{description}

🔗 Website ⋮ {link}
📅 Release Date ⋮ {date}`;
                        insertAtCursor(newReleaseText);
                    } else {
                        console.log(`Process button clicked: ${action}`);
                        // Future action will be implemented here
                    }
                });
            });

            // Update dropdown option event listeners
            const updateOptions = document.querySelectorAll('.update-option');
            updateOptions.forEach((option) => {
                option.addEventListener('click', (e) => {
                    e.preventDefault();
                    const updateType = option.dataset.option;
                    let updateText = '';

                    switch(updateType) {
                        case 'website':
                            updateText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
เปิดตัวเว็บไซต์ทางการ

{romaji}
{japanese}

🔗 Website ⋮ {link}`;
                            break;
                        case 'cast':
                            updateText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
เปิดเผยรายชื่อนักพากย์

{romaji}
{japanese}

🔗 Website ⋮ {link}`;
                            break;
                        case 'release-date':
                            updateText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
กำหนดวันวางจำหน่าย

{romaji}
{japanese}

📅 Release Date ⋮ {date}
🔗 Website ⋮ {link}`;
                            break;
                        case 'delay':
                            updateText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่
เลื่อนวันวางจำหน่าย

{romaji}
{japanese}

📅 New Release Date ⋮ {date}
🔗 Website ⋮ {link}`;
                            break;
                        case 'other':
                            updateText = `【NEWS】 ⇒ Updates

ผู้พัฒนาเกม {developer} อัปเดตข้อมูลใหม่

{romaji}
{japanese}

🔗 Website ⋮ {link}`;
                            break;
                    }

                    insertAtCursor(updateText);
                });
            });

            // Announcement dropdown option event listeners
            const announcementOptions = document.querySelectorAll('.announcement-option');
            announcementOptions.forEach((option) => {
                option.addEventListener('click', (e) => {
                    e.preventDefault();
                    const announcementType = option.dataset.option;
                    let announcementText = '';

                    if (announcementType === 'new-game') {
                        announcementText = `【NEWS】 ⇒ Announcements

ผู้พัฒนาเกม {developer} 
เปิดตัวเกมใหม่อย่างเป็นทางการ

{romaji}
{japanese}

{description}

🔗 Website ⋮ {link}
📅 Release Date ⋮ {date}`;
                    } else if (announcementType === 'other') {
                        announcementText = `【NEWS】 ⇒ Announcements

ผู้พัฒนาเกม {developer} `;
                    }

                    insertAtCursor(announcementText);
                });
            });

            clearBtn.addEventListener('click', () => {
                if (confirm('Clear the entire editor content?')) {
                    editor.value = '';
                    editor.focus();
                }
            });

            const showCopyFeedback = (success) => {
                if (!copyBtn) return;
                const originalHtml = copyBtn.dataset.originalHtml ?? copyBtn.innerHTML;
                copyBtn.dataset.originalHtml = originalHtml;
                copyBtn.disabled = true;
                copyBtn.innerHTML = success
                    ? '<i class="fas fa-check me-2"></i>Copied!'
                    : '<i class="fas fa-exclamation-triangle me-2"></i>Copy failed';
                setTimeout(() => {
                    copyBtn.innerHTML = copyBtn.dataset.originalHtml;
                    copyBtn.disabled = false;
                }, 2000);
            };

            const fallbackCopy = (text) => {
                const tempTextarea = document.createElement('textarea');
                tempTextarea.value = text;
                tempTextarea.style.position = 'fixed';
                tempTextarea.style.top = '-9999px';
                document.body.appendChild(tempTextarea);
                tempTextarea.focus();
                tempTextarea.select();
                let successful = false;
                try {
                    successful = document.execCommand('copy');
                } catch (err) {
                    successful = false;
                }
                document.body.removeChild(tempTextarea);
                return successful;
            };

            copyBtn?.addEventListener('click', async () => {
                const text = editor.value;
                if (!text) {
                    showCopyFeedback(true);
                    return;
                }

                try {
                    if (navigator.clipboard?.writeText) {
                        await navigator.clipboard.writeText(text);
                        showCopyFeedback(true);
                    } else {
                        const fallbackSuccess = fallbackCopy(text);
                        showCopyFeedback(fallbackSuccess);
                    }
                } catch (err) {
                    const fallbackSuccess = fallbackCopy(text);
                    showCopyFeedback(fallbackSuccess);
                }
            });
        });
    </script>
</body>